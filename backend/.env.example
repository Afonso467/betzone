PORT=3001
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=novacrates
# Define DB_SSL=true se a base de dados exigir SSL (ex: Aiven, PlanetScale, etc.)
DB_SSL=false
# Em produção, separa várias origens por vírgula (sem espaços), ex:
# CORS_ORIGIN=http://localhost:5173,https://o-teu-user.github.io
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Password de acesso ao painel de administração (/admin no frontend).
# Define aqui uma password à tua escolha — é pedida no painel para
# criar jogos, editar odds e definir resultados.
ADMIN_PASSWORD=admin123

# ── Autenticação de utilizadores (login/registo) ──────────────────────────
# Segredo usado para assinar os tokens JWT. MUDA isto para um valor longo
# e aleatório em produção — nunca deixes o valor de exemplo num site real.
JWT_SECRET=muda_isto_para_um_segredo_longo_e_aleatorio_em_producao
JWT_EXPIRES_IN=7d
# Número de "rounds" do bcrypt ao encriptar passwords (10-12 é o recomendado)
BCRYPT_ROUNDS=12
